                  <%= list.title || 'Lista de lectura' %>
                </p>
              </div>
              <% }) %>
                <% } else { %>
                  <p class="empty-text text-muted">No hay listas de lectura públicas aún.</p>
                  <% } %>
        </div>

        <h3>Obras creadas</h3>
        <div class="library-grid mt-1">
          <% if (user.works && user.works.length> 0) { %>
            <% user.works.forEach(work=> { %>
              <div class="library-item">
                <a href="/historias/<%= work.id || work.id_cuento %>">
                  <img src="<%= work.cover || work.portada_url || '/img/default-portada.jpg' %>" class="cover"
                    alt="Obra">
                </a>
                <p class="title mt-05">
                  <%= work.titulo || work.title || 'Historia sin título' %>
                </p>
              </div>
              <% }) %>
                <% } else { %>
                  <p class="empty-text text-muted">Este usuario aún no ha publicado historias.</p>
                  <% } %>
        </div>
      </div>
    </div>
