<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Crear historia | Willpig Studio</title>
  <link rel="stylesheet" href="/css/style1.2.css" />
  <link rel="icon" href="/img/img.ico/logo.ico" />
</head>

<body>

  <%- include('partials/navbar', { loggerUser }) %>

    <!-- Barra superior -->
    <header class="story-header">
      <div class="header-left">
        <a href="/" class="back-link">← Volver</a>
        <h2>Agregar información de la historia</h2>
      </div>

      <div class="header-actions">
        <a href="/" class="btn-canceler">Cancelar</a>
        <button type="submit" form="story-form" class="btn-savever">Guardar</button>
      </div>
    </header>

    <main class="new-storys">

      <!-- Portada -->
      <div class="story-cover">
        <label for="portada" class="cover-box">
          <img src="/img/img.ico/image-icon.png" class="cover-icon">
          <p>Añadir una portada</p>
        </label>
        <input type="file" id="portada" name="portada" accept="image/*" form="story-form" hidden>
      </div>

      <!-- Formulario -->
      <form id="story-form" class="story-form" action="/historias/new" method="POST" enctype="multipart/form-data">

        <section class="story-details">
          <h3>Detalles de la historia</h3>

          <div class="form-group">
            <label for="titulo">Título</label>
            <input type="text" id="titulo" name="titulo" required>
          </div>

          <div class="form-group">
            <label for="descripcion">Descripción</label>
            <textarea id="descripcion" name="descripcion"></textarea>
          </div>

          <div class="form-group">
            <label for="audiencia">Audiencia</label>
            <select id="audiencia" name="audiencia" required>
              <option value="">Selecciona una audiencia</option>
              <option value="todo_publico">Todo público</option>
              <option value="juvenil">Juvenil</option>
              <option value="adulto">Adulto</option>
            </select>
          </div>

          <div class="form-group">
            <label for="idioma">Idioma</label>
            <select id="idioma" name="idioma" required>
              <option value="es">Español</option>
              <option value="en">Inglés</option>
            </select>
          </div>

          <div class="form-group">
            <label for="derechos">Derechos de autor</label>
            <select id="derechos" name="derechos" required>
              <option value="todos">Todos los derechos reservados</option>
              <option value="creative_commons">Privado</option>
              <option value="dominio_publico">Público</option>
            </select>
          </div>

          <div class="form-group">
            <label for="categoria">Categoría</label>
            <select id="categoria" name="categoria_id" required> <!-- Changed name to match controller -->
              <option value="">Selecciona una categoría</option>
              <option value="1">Fantasía</option> <!-- Assumption: IDs are 1-based, need to verify -->
              <option value="2">Romance</option>
              <option value="3">Aventura</option>
              <option value="4">Drama</option>
              <option value="5">Infantil</option>
            </select>
          </div>

          <div class="form-group">
            <label>Clasificación</label>
            <label><input type="radio" name="clasificacion" value="todo" checked> Todo público</label>
            <label><input type="radio" name="clasificacion" value="maduro"> Maduro</label>
          </div>

          <div class="form-group">
            <label>Visibilidad</label>
            <label><input type="radio" name="visibilidad" value="publica" checked> Público</label>
            <label><input type="radio" name="visibilidad" value="privada"> Privado</label>
          </div>

        </section>
      </form>
    </main>

</body>

</html>


<%- include('partials/footer') %>
  </body>
  <script>
    const input = document.getElementById("portada");
    const label = document.querySelector(".cover-box");

    input.addEventListener("change", function () {
      const file = this.files[0];
      if (file) {
        const imgURL = URL.createObjectURL(file);
        label.innerHTML = `<img src="${imgURL}" style="width:100%; height:100%; object-fit:cover; border-radius:12px;">`;
      }
    });
  </script>

  </html>