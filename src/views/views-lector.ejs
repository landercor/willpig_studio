<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Detalle de Historia</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css">
  
  <link rel="stylesheet" href="/css/modules/views/lector.css">
</head>
<body>

<div class="story-page" id="app">
  <div class="modal-overlay" id="modal-overlay">
    <div class="modal">
      <h3>Nueva parte</h3>
      <input type="text" id="modal-input" placeholder="Título...">
      <br>
      <button onclick="closeModal()">Cancelar</button> 
      <button onclick="saveModal()" style="background:#f5a623; color:#fff; border:none; padding:4px 8px; cursor:pointer;">Guardar</button>
    </div>
  </div>

  <div class="banner">
    <div class="cover" onclick="document.getElementById('cover-upload').click()">
      <img id="cover-img" style="display:none"> 
      <span id="cover-ph">Portada</span>
    </div>
    <input type="file" id="cover-upload" style="display:none" accept="image/*" onchange="changeCover(event)">
    
    <div class="story-info">
      <div class="story-title" id="story-title">Ejemplo</div>
      <div class="story-stats"><span id="stat-parts">1 Parte</span> • 0 Lecturas • 0 Votos</div>
      <div class="author">Por AleDawson</div>
    </div>
  </div>

  <div class="body-section">
    <button class="btn-edit" id="edit-btn" onclick="toggleEditMode()">Editar historia</button>
    <div class="story-desc" id="story-desc">sdhjfdhjfdjkdsfdff</div>
    <span class="tag">No ficción</span>
    
    <div class="toc-header">
      <span>Tabla de Contenidos</span>
      <a href="#" onclick="openModal()" style="color:#0284c7; text-decoration:none;">+ Nueva parte</a>
    </div>
    
    <table class="parts-table">
      <thead>
        <tr><th>Parte</th><th>Fecha</th><th>Estado</th><th></th></tr>
      </thead>
      <tbody id="parts-tbody"></tbody>
    </table>
  </div>
</div>

<script>
    
var editMode = false;
var parts = [{title: "Parte 1 sin título", date: "Dec 18, 2014"}];

// --- FUNCIONES INTERACTIVAS ---
function toggleEditMode() {
  editMode = !editMode;
  document.getElementById('story-title').contentEditable = editMode;
  document.getElementById('story-desc').contentEditable = editMode;
  
  var btn = document.getElementById('edit-btn');
  btn.textContent = editMode ? "Guardar cambios" : "Editar historia";
  btn.style.background = editMode ? "#9b3e00" : "#ff893a";
  renderParts();
}

function renderParts() {
  document.getElementById('stat-parts').textContent = parts.length + ' Parte' + (parts.length !== 1 ? 's' : '');
  document.getElementById('parts-tbody').innerHTML = parts.map((p, i) => `
    <tr>
      <td style="color:#0284c7; font-weight:500;">${p.title}</td>
      <td>${p.date}</td>
      <td><span class="badge">Borrador</span></td>
      <td>${editMode ? `<i class="ti ti-trash" onclick="deletePart(${i})" style="cursor:pointer;color:red;"></i>` : '—'}</td>
    </tr>`).join('');
}

function openModal() { document.getElementById('modal-overlay').style.display = 'flex'; }
function closeModal() { document.getElementById('modal-overlay').style.display = 'none'; document.getElementById('modal-input').value = ''; }
function deletePart(i) { if(confirm('¿Eliminar esta parte?')) { parts.splice(i, 1); renderParts(); } }

function saveModal() {
  var t = document.getElementById('modal-input').value.trim();
  if(!t) return;
  parts.push({title: t, date: new Date().toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric'})});
  closeModal(); 
  renderParts();
}

function changeCover(e) {
  var f = e.target.files[0]; if(!f) return;
  var r = new FileReader(); r.onload = function(ev){
    document.getElementById('cover-img').src = ev.target.result;
    document.getElementById('cover-img').style.display = 'block';
    document.getElementById('cover-ph').style.display = 'none';
  }; r.readAsDataURL(f);
}

renderParts();
</script>
</body>
</html>