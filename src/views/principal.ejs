<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title> Willpig Studio | Principal</title>
  <link rel="stylesheet" href="/css/style1.2.css" />
  <link rel="icon" href="/img/img.ico/logo.ico">
</head>

<%- include('partials/navbar', { loggerUser }) %>

  <body>

    <!-- Carrusel principal -->
    <section class="hero-carousel">
      <div class="carousel">
        <% carrusel.forEach((item, index)=> { %>
          <div class="slide <%= index === 0 ? 'active': '' %>">
            <img src="<%= item.imagen %>">
            <div class="caption">
              <h2>
                <%= item.titulo %>
              </h2>
              <a href="<%= item.link %>">
                <button>Leer ahora</button>
              </a>
            </div>
          </div>

          <% }) %>

      </div>

      <div class="carousel-controls">
        <button class="prev"> &lt; </button>
        <button class="next"> &gt; </button>
      </div>
    </section>

    <!-- Secciones con scroll horizontal -->
    <section class="library-page">
      <div class="library-header">
        <div class="library-tabs">
        </div>
      </div>

      <div class="library-content">
        <!-- === Lecturas actuales === -->
        <div id="current-reads" class="tab-content active">
          <div class="section-title"> Nuevas historias </div>

          <div class="library-grid">
            <% libros.forEach(libro=> { %>
              <div class="library-item">
                <a href="/historias/<%= libro.id_cuento || '#' %>">
                  <img src="<%= libro.portada || '/img/default-portada.jpg' %>" class="cover" alt="<%= libro.titulo %>">
                </a>

                <p class="title">
                  <%= libro.titulo %>
                </p>

                <div class="author">
                  <img
                    src="<%= (libro.cuenta_usuario && libro.cuenta_usuario.avatar_url) || '/img/img.ico/user-icon.png' %>"
                    alt="autor">
                  <span>@<%= (libro.cuenta_usuario && libro.cuenta_usuario.username) || 'Anónimo' %></span>
                </div>

                <div class="meta">
                  <img src="/img/img.ico/vistas-icon.svg" class="icon-eye">
                  <%= libro.vistas %>
                </div>
              </div>
              <% }) %>
          </div>


          <!-- Historia destacada -->
          <section class="featured-story">
            <img src="/img/Amigo Oso no puede dormir.jpg" alt="Historia destacada">
            <div class="info">
              <h2>Historia destacada</h2>
              <p>Una aventura mágica que combina el poder de la imaginación con el misterio de los sueños perdidos.</p>
              <button class="leer_story">Leer ahora</button>
            </div>
          </section>

          <%- include('partials/footer') %>

            <script src="script.js"></script>
  </body>

</html>