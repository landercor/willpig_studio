<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WillPig Studio - Historias que conectan</title>
    <link rel="stylesheet" href="/css/style1.2.css?v=2">
    <link rel="icon" href="/img/img.ico/logo.ico">
</head>

<body>
    <%- include('partials/navbar', { loggerUser: typeof loggerUser !=='undefined' ? loggerUser : null }) %>

        <main>
            <section class="hero-landing">
                <div class="hero-content reveal-item">
                    <h1 class="hero-title">Ven por la historia. <br> Quédate por la conexión.</h1>
                    <p class="hero-description">
                        Historias mejores que un streaming y comentarios que superan tus discusiones de grupo. Únete a
                        la comunidad de WillPig Studio.
                    </p>
                    <div class="hero-btns">
                        <a href="/auth/register" class="hero-btn-main">Comenzar</a>
                        <div class="hero-login-link">
                            ¿Ya tienes una cuenta? <a href="/auth/login">Inicia sesión</a>
                        </div>
                    </div>
                </div>
                <div class="hero-illustration">
                    <img src="/img/default-landing.jpg" alt="Ilustración de comunidad y lectura" class="animate-scale">
                </div>
            </section>

            <!-- About WillPig Section -->
            <section class="landing-about reveal-item">
                <div class="about-content">
                    <h2>Sobre WillPig Studio</h2>
                    <p>Su propósito principal es que los usuarios con
                        dificultades para mantener un nivel de atención adecuado, puedan mejorar en este ámbito a través
                        de libros ilustrados digitales, cuales se encuentran en el aplicativo, libros de múltiples
                        categorías, infantiles, adolescentes, y adultos.</p>
                </div>
            </section>

            <!-- Genres Section -->
            <section class="landing-genres reveal-item">
                <div class="genres-header">
                    <h2>Todos los géneros. Todos los arquetipos. Todos tuyos.</h2>
                    <p>Encuentra tu próxima lectura favorita, sea cual sea tu estado de ánimo (sin juzgar).</p>
                </div>
                <div class="genres-grid">
                    <a href="/buscar?q=romance" class="genre-card">
                        <div class="genre-icon">💖</div>
                        <h3>Romance</h3>
                    </a>
                    <a href="/buscar?q=ficcion" class="genre-card">
                        <div class="genre-icon">🌌</div>
                        <h3>Ficción general</h3>
                    </a>
                    <a href="/buscar?q=aleatorio" class="genre-card">
                        <div class="genre-icon">🎲</div>
                        <h3>Aleatorio</h3>
                    </a>
                    <a href="/buscar?q=aventura" class="genre-card">
                        <div class="genre-icon">🗺️</div>
                        <h3>Aventura</h3>
                    </a>
                    <a href="/buscar?q=fanfiction" class="genre-card">
                        <div class="genre-icon">🎭</div>
                        <h3>Fanfiction</h3>
                    </a>
                    <a href="/buscar?q=adolescentes" class="genre-card">
                        <div class="genre-icon">🎒</div>
                        <h3>Adolescentes</h3>
                    </a>
                    <a href="/buscar?q=accion" class="genre-card">
                        <div class="genre-icon">⚔️</div>
                        <h3>Acción</h3>
                    </a>
                    <a href="/buscar?q=infantil" class="genre-card">
                        <div class="genre-icon">🧸</div>
                        <h3>Infantil</h3>
                    </a>
                </div>
            </section>

            <!-- Trending Carousel Placeholder -->
            <section class="landing-trending reveal-item">
                <div class="trending-header">
                    <h2>Tendencias actuales</h2>
                    <a href="/buscar" class="view-all-link">Ver todas <span>→</span></a>
                </div>
                <div class="trending-carousel-wrapper">
                    <div class="trending-carousel">
                        <!-- Placeholders -->
                        <div class="trending-card">
                            <img src="/img/debajo_de_la_luna.jpg" onerror="this.src='/img/default-book.jpg'"
                                alt="Portada" class="trending-cover">
                            <div class="trending-info">
                                <h4>Bajo cielos clementes</h4>
                            </div>
                        </div>
                        <div class="trending-card">
                            <img src="/img/Alicia.jpg" onerror="this.src='/img/default-book.jpg'" alt="Portada"
                                class="trending-cover">
                            <div class="trending-info">
                                <h4>Alicia</h4>
                            </div>
                        </div>
                        <div class="trending-card">
                            <img src="/img/la flor de otoño.jpg" onerror="this.src='/img/default-book.png'"
                                alt="Portada" class="trending-cover">
                            <div class="trending-info">
                                <h4>Caperucita Roja</h4>
                            </div>
                        </div>
                        <div class="trending-card">
                            <img src="/img/placeholder.jpg" onerror="this.src='/img/default-book.jpg'" alt="Portada"
                                class="trending-cover">
                            <div class="trending-info">
                                <h4>Cenicienta</h4>
                            </div>
                        </div>
                        <div class="trending-card">
                            <img src="/img/placeholder2.jpg" onerror="this.src='/img/default-book.jpg'" alt="Portada"
                                class="trending-cover">
                            <div class="trending-info">
                                <h4>Hombres Lobos</h4>
                            </div>
                        </div>
                        <div class="trending-card">
                            <img src="/img/placeholder1.jpg" onerror="this.src='/img/default-book.jpg'" alt="Portada"
                                class="trending-cover">
                            <div class="trending-info">
                                <h4>Hombres Lobos</h4>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Promotional Banner Section -->
            <section class="landing-banner reveal-item">
                <div class="banner-content">
                    <h2>Fanfiction que debes leer sin falta</h2>
                    <a href="/buscar?q=fanfiction" class="btn-primary-pastel">Explorar ahora</a>
                </div>
            </section>
        </main>

        <%- include('partials/footer') %>

            <script>
                // Reveal animation
                document.addEventListener('DOMContentLoaded', () => {
                    setTimeout(() => {
                        const revealItems = document.querySelectorAll('.reveal-item');
                        revealItems.forEach(item => {
                            item.classList.add('visible');
                        });
                    }, 100);
                });
            </script>
</body>

</html>