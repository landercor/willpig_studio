<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= tituloPagina %></title>
  <link rel="stylesheet" href="/css/style1.2.css" />
  <link rel="icon" href="/img/img.ico/logo.ico">
</head>

<body>
  <%- include('partials/navbar', { loggerUser }) %>

  <main style="padding: 2rem;">
    <div class="editor-container">
      <!-- Sidebar with existing chapters -->
      <aside class="editor-sidebar">
        <h3>Capítulos</h3>
        <ul class="chapter-list">
          <% if (chapters && chapters.length > 0) { %>
            <% chapters.forEach((cap, index) => { %>
              <li>
                <a href="/capitulos/read/<%= cap.id_capitulo %>" target="_blank">
                  Capítulo <%= index + 1 %>: <%= cap.titulo %>
                </a>
              </li>
            <% }) %>
          <% } else { %>
            <p style="color: #888; font-size: 0.9rem; font-style: italic;">Aún no hay capítulos escritos.</p>
          <% } %>
        </ul>
        <div style="margin-top: 1rem; text-align: center;">
            <a href="/historias/mis" style="color: #ff6b6b; text-decoration: none; font-weight: bold;">← Volver a Mis Historias</a>
        </div>
      </aside>

      <!-- Main Editor Area -->
      <section class="editor-main">
        <div class="editor-header">
          <h2>Redactar Nuevo Capítulo</h2>
          <p style="color: #666; margin-top: 0.5rem;">Añadiendo contenido a <strong><%= story.titulo %></strong></p>
        </div>

        <form action="/capitulos/new" method="POST" class="editor-form">
          <input type="hidden" name="cuento_id" value="<%= story.id_cuento %>">
          
          <div class="form-group">
            <label for="titulo">Título del Capítulo</label>
            <input type="text" id="titulo" name="titulo" placeholder="Ej. El comienzo del viaje" required>
          </div>

          <div class="form-group">
            <label for="contenido">Contenido</label>
            <textarea id="contenido" name="contenido" placeholder="Érase una vez..." required></textarea>
          </div>

          <button type="submit" class="btn-publish">Publicar Capítulo</button>
        </form>
      </section>
    </div>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
