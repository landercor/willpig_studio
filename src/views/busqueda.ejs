<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= tituloPagina %></title>
  <link rel="stylesheet" href="/css/style1.2.css" />
  <link rel="icon" href="/img/img.ico/logo.ico">
</head>

<body>
  <%- include('partials/navbar', { loggerUser }) %>

  <!-- ===== BÚSQUEDA ===== -->
  <section class="library-page search-page">
    <div class="library-header">
      <h1 class="text-primary">Resultados de búsqueda</h1>
      <p class="text-muted mt-05">Buscando por: "<%= query %>"</p>
    </div>

    <div class="library-content">
      <div id="search-results" class="tab-content active mt-2">
        
        <div class="library-grid">
          <% if (resultados && resultados.length > 0) { %>
            <% resultados.forEach(libro=> { %>
              <div class="library-item">
                <a href="/historias/<%= libro.id_cuento || '#' %>">
                  <img src="<%= libro.portada_url || libro.portada || '/img/default-portada.jpg' %>" class="cover" alt="<%= libro.titulo %>">
                </a>
                <p class="title"><%= libro.titulo %></p>
                <div class="author">
                  <img src="<%= (libro.cuenta_usuario && libro.cuenta_usuario.avatar_url) || '/img/img.ico/user-icon.png' %>" alt="autor">
                  <span>@<%= (libro.cuenta_usuario && libro.cuenta_usuario.username) || 'Anónimo' %></span>
                </div>
                <div class="meta">
                  <img src="/img/img.ico/vistas-icon.svg" class="icon-eye"> <%= libro.vistas || 0 %>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <div class="empty-state empty-card text-center text-muted p-3 col-full">
              <h3 class="mb-05">No encontramos historias que coincidan con "<%= query %>"</h3>
              <p>Intenta buscar con otras palabras o explora la página principal.</p>
              <a href="/"><button class="btn btn-primary mt-1-5">Volver al Inicio</button></a>
            </div>
          <% } %>
        </div>

      </div>
    </div>
  </section>

  <%- include('partials/footer') %>
  <script src="/js/script.js"></script>
</body>

</html>
