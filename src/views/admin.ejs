                                  </div>

                                  <!-- Modal: Nuevo Capítulo -->
                                  <div id="modal-new-capitulo" class="modal-overlay">
                                    <div class="modal-content">
                                      <div class="modal-header">
                                        <h2>Nuevo Capítulo</h2>
                                        <button type="button" class="close-modal"
                                          onclick="closeModal('modal-new-capitulo')">&times;</button>
                                      </div>
                                      <form method="POST" action="/admin/capitulos/new">
                                        <div class="form-grid">
                                          <div class="form-group span-full">
                                            <label>ID del Cuento *</label>
                                            <input type="number" name="cuento_id" class="form-control"
                                              placeholder="ID del cuento al que pertenece" required>
                                          </div>
                                          <div class="form-group span-full">
                                            <label>Título del Capítulo *</label>
                                            <input type="text" name="titulo" class="form-control"
                                              placeholder="Título del capítulo" required>
                                          </div>
                                        </div>
                                        <div class="modal-footer">
                                          <button type="button" class="btn btn-outline"
                                            onclick="closeModal('modal-new-capitulo')">Cancelar</button>
