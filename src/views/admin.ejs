<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Willpig Studio | Panel de Administrador</title>
  <link rel="stylesheet" href="/css/modules/views/admin.css" />
  <link rel="icon" href="/img/img.ico/GABALI baloo.ico">
</head>
<body>

<div class="admin-layout">

  <!-- ── SIDEBAR ─────────────────────────────────── -->
  <aside class="admin-sidebar">
    <div class="sidebar-header">
      <span class="sidebar-logo">⚙ Admin</span>
      <small><%= loggerUser ? loggerUser.username : 'Admin' %></small>
    </div>

    <nav class="sidebar-nav">
      <a href="/admin"           class="nav-link <%= seccion === 'dashboard'  ? 'active' : '' %>">📊 Dashboard</a>
      <a href="/admin/usuarios"  class="nav-link <%= seccion === 'usuarios'   ? 'active' : '' %>">👤 Usuarios</a>
      <a href="/admin/historias" class="nav-link <%= seccion === 'historias'  ? 'active' : '' %>">📚 Historias</a>
      <a href="/admin/categorias"class="nav-link <%= seccion === 'categorias' ? 'active' : '' %>">🏷 Categorías</a>
    </nav>

    <div class="sidebar-footer">
      <a href="/" class="nav-link">← Volver al sitio</a>
    </div>
  </aside>

  <!-- ── CONTENIDO PRINCIPAL ──────────────────────── -->
  <main class="admin-main">

    <!-- Mensajes de éxito / error -->
    <% if (mensaje) { %>
      <div class="alert alert-ok"><%= mensaje %></div>
    <% } %>
    <% if (error) { %>
      <div class="alert alert-err"><%= error %></div>
    <% } %>

    <!-- ====================================================
         DASHBOARD
    ==================================================== -->
    <% if (seccion === 'dashboard') { %>
      <h1 class="page-title">Dashboard</h1>

      <div class="stats-grid">
        <div class="stat-card">
          <span class="stat-num"><%= stats.totalUsuarios || 0 %></span>
          <span class="stat-label">Usuarios</span>
        </div>
        <div class="stat-card">
          <span class="stat-num"><%= stats.totalHistorias || 0 %></span>
          <span class="stat-label">Historias</span>
        </div>
        <div class="stat-card">
          <span class="stat-num"><%= stats.totalCapitulos || 0 %></span>
          <span class="stat-label">Capítulos</span>
        </div>
        <div class="stat-card">
          <span class="stat-num"><%= stats.totalCategorias || 0 %></span>
          <span class="stat-label">Categorías</span>
        </div>
      </div>

      <div class="quick-links">
        <h2>Accesos rápidos</h2>
        <div class="link-grid">
          <a href="/admin/usuarios"   class="quick-btn">👤 Gestionar Usuarios</a>
          <a href="/admin/historias"  class="quick-btn">📚 Gestionar Historias</a>
          <a href="/admin/categorias" class="quick-btn">🏷 Gestionar Categorías</a>
        </div>
      </div>

    <!-- ====================================================
         USUARIOS
    ==================================================== -->
    <% } else if (seccion === 'usuarios') { %>
      <h1 class="page-title">Gestión de Usuarios</h1>

      <% if (usuarios.length === 0) { %>
        <p>No hay usuarios registrados.</p>
      <% } else { %>
        <div class="table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>#</th>
                <th>Username</th>
                <th>Email</th>
                <th>Rol</th>
                <th>Estado</th>
                <th>Registrado</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody>
              <% usuarios.forEach(u => { %>
              <tr>
                <td><%= u.id_cuenta_usuario %></td>
                <td><strong><%= u.username %></strong></td>
                <td><%= u.email %></td>

                <!-- Editar rol -->
                <td>
                  <form method="POST" action="/admin/usuarios/<%= u.id_cuenta_usuario %>/edit" class="inline-form">
                    <input type="hidden" name="estado" value="<%= u.estado %>">
                    <select name="rol" class="sel-small" onchange="this.form.submit()">
                      <option value="lector"     <%= u.rol === 'lector'     ? 'selected' : '' %>>lector</option>
                      <option value="escritor"   <%= u.rol === 'escritor'   ? 'selected' : '' %>>escritor</option>
                      <option value="moderador"  <%= u.rol === 'moderador'  ? 'selected' : '' %>>moderador</option>
                      <option value="admin"      <%= u.rol === 'admin'      ? 'selected' : '' %>>admin</option>
                    </select>
                  </form>
                </td>

                <!-- Editar estado -->
                <td>
                  <form method="POST" action="/admin/usuarios/<%= u.id_cuenta_usuario %>/edit" class="inline-form">
                    <input type="hidden" name="rol" value="<%= u.rol %>">
                    <select name="estado" class="sel-small" onchange="this.form.submit()">
                      <option value="activa"        <%= u.estado === 'activa'        ? 'selected' : '' %>>activa</option>
                      <option value="suspendida"    <%= u.estado === 'suspendida'    ? 'selected' : '' %>>suspendida</option>
                      <option value="deshabilitada" <%= u.estado === 'deshabilitada' ? 'selected' : '' %>>deshabilitada</option>
                    </select>
                  </form>
                </td>

                <td><%= u.fecha_registro ? new Date(u.fecha_registro).toLocaleDateString('es') : '—' %></td>

                <!-- Eliminar -->
                <td>
                  <form method="POST" action="/admin/usuarios/<%= u.id_cuenta_usuario %>/delete"
                        onsubmit="return confirm('¿Eliminar usuario <%= u.username %>?')">
                    <button type="submit" class="btn btn-del">Eliminar</button>
                  </form>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>

    <!-- ====================================================
         HISTORIAS
    ==================================================== -->
    <% } else if (seccion === 'historias') { %>
      <h1 class="page-title">Gestión de Historias</h1>

      <% if (historias.length === 0) { %>
        <p>No hay historias registradas.</p>
      <% } else { %>
        <div class="table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>#</th>
                <th>Título</th>
                <th>Autor</th>
                <th>Estado</th>
                <th>Visibilidad</th>
                <th>Vistas</th>
                <th>Fecha</th>
                <th>Eliminar</th>
              </tr>
            </thead>
            <tbody>
              <% historias.forEach(h => { %>
              <tr>
                <td><%= h.id_cuento %></td>
                <td>
                  <a href="/historias/<%= h.id_cuento %>" target="_blank" class="link-title">
                    <%= h.titulo %>
                  </a>
                </td>
                <td><%= h.cuenta_usuario ? h.cuenta_usuario.username : '—' %></td>

                <!-- Editar estado -->
                <td>
                  <form method="POST" action="/admin/historias/<%= h.id_cuento %>/edit" class="inline-form">
                    <input type="hidden" name="visibilidad" value="<%= h.visibilidad %>">
                    <select name="estado" class="sel-small" onchange="this.form.submit()">
                      <option value="borrador"   <%= h.estado === 'borrador'   ? 'selected' : '' %>>borrador</option>
                      <option value="progreso"   <%= h.estado === 'progreso'   ? 'selected' : '' %>>progreso</option>
                      <option value="publicado"  <%= h.estado === 'publicado'  ? 'selected' : '' %>>publicado</option>
                    </select>
                  </form>
                </td>

                <!-- Editar visibilidad -->
                <td>
                  <form method="POST" action="/admin/historias/<%= h.id_cuento %>/edit" class="inline-form">
                    <input type="hidden" name="estado" value="<%= h.estado %>">
                    <select name="visibilidad" class="sel-small" onchange="this.form.submit()">
                      <option value="publica"  <%= h.visibilidad === 'publica'  ? 'selected' : '' %>>pública</option>
                      <option value="privada"  <%= h.visibilidad === 'privada'  ? 'selected' : '' %>>privada</option>
                    </select>
                  </form>
                </td>

                <td><%= (h.vistas || 0).toLocaleString() %></td>
                <td><%= h.created_at ? new Date(h.created_at).toLocaleDateString('es') : '—' %></td>

                <!-- Eliminar -->
                <td>
                  <form method="POST" action="/admin/historias/<%= h.id_cuento %>/delete"
                        onsubmit="return confirm('¿Eliminar historia: <%= h.titulo %>?')">
                    <button type="submit" class="btn btn-del">Eliminar</button>
                  </form>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>

    <!-- ====================================================
         CATEGORÍAS
    ==================================================== -->
    <% } else if (seccion === 'categorias') { %>
      <h1 class="page-title">Gestión de Categorías</h1>

      <!-- Formulario crear categoría -->
      <div class="form-card">
        <h2>Nueva categoría</h2>
        <form method="POST" action="/admin/categorias/new" class="row-form">
          <input type="text" name="nombre" placeholder="Nombre de la categoría" required class="inp">
          <button type="submit" class="btn btn-ok">Crear</button>
        </form>
      </div>

      <% if (categorias.length === 0) { %>
        <p>No hay categorías registradas.</p>
      <% } else { %>
        <div class="table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>#</th>
                <th>Nombre</th>
                <th>Editar</th>
                <th>Eliminar</th>
              </tr>
            </thead>
            <tbody>
              <% categorias.forEach(c => { %>
              <tr>
                <td><%= c.id_categoria %></td>
                <td>

                  <!-- Editar nombre inline -->
                  <form method="POST" action="/admin/categorias/<%= c.id_categoria %>/edit" class="row-form">
                    <input type="text" name="nombre" value="<%= c.nombre %>" required class="inp inp-sm">
                    <button type="submit" class="btn btn-edit">Guardar</button>
                  </form>

                </td>
                <td>—</td>

                <!-- Eliminar -->
                <td>
                  <form method="POST" action="/admin/categorias/<%= c.id_categoria %>/delete"
                        onsubmit="return confirm('¿Eliminar categoría <%= c.nombre %>?')">
                    <button type="submit" class="btn btn-del">Eliminar</button>
                  </form>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>

    <% } %>

  </main>
</div>

</body>
</html>