      <div class="library-content">
        <!-- === INICIO (Filas Netflix & Destacada) === -->
        <div id="home-tab" class="tab-content active">

          <!-- Historia destacada -->
          <% if (typeof PanelRender !=='undefined' && PanelRender) { %>
            <%# %>
            <section class="featured-panel mb-3 adm-items-">
              <div class="featured-adm-pnt">
                <img
                  src="<%= PanelRender.portada_url || PanelRender.portada || '/img/default-portada.jpg' %>"
                  alt="<%= PanelRender.titulo %>">
                <div class="featured-badge">Destacada</div>
              </div>
              <div class="info">
                <h2>Recomendación del día</h2>
                <h3 class="mb-05">
                  <%= PanelRender.titulo %>
                </h3>
                <p>
                  <%= PanelRender.sinopsis
                    || 'Una aventura increíble y popular elegida por los lectores de Willpig Studio.' %>
                </p>
                <div class="featured-meta">
                  <div class="meta-item"><img src="/img/img.ico/vistas-icon.svg" class="icon-eye"> <span>
                      <%= (PanelRender.vistas || 0).toLocaleString() %> lecturas
                    </span></div>
