                                        </div>
                                      </form>
                                    </div>
                                  </div>

                                  <% if (capitulos.length===0) { %>
                                    <p>No hay capítulos registrados.</p>
                                    <% } else { %>
                                      <div class="table-wrap">
                                        <table class="admin-table">
                                          <thead>
                                            <tr>
                                              <th>#</th>
                                              <th>Título</th>
                                              <th>Cuento</th>
                                              <th>Fecha</th>
                                              <th>Editar</th>
                                              <th>Eliminar</th>
                                            </tr>
                                          </thead>
                                          <tbody>
                                            <% capitulos.forEach(c=> { %>
                                              <tr>
                                                <td>
                                                  <%= c.id_capitulo %>
                                                </td>
                                                <td>
                                                  <%= c.titulo %>
                                                </td>
                                                <td>
                                                  <%= c.cuentos ? c.cuentos.titulo : c.cuento_id %>
                                                </td>
                                                <td>
                                                  <%= c.created_at ? new Date(c.created_at).toLocaleDateString() : '' %>
                                                </td>
                                                <td>
                                                  <button type="button" class="btn btn-edit btn-sm"
                                                    onclick="openModal('modal-edit-cap-<%= c.id_capitulo %>')">Editar</button>
                                                  <div id="modal-edit-cap-<%= c.id_capitulo %>" class="modal-overlay">
                                                    <div class="modal-content">
                                                      <div class="modal-header">
                                                        <h2>Editar Capítulo</h2>
                                                        <button type="button" class="close-modal"
                                                          onclick="closeModal('modal-edit-cap-<%= c.id_capitulo %>')">&times;</button>
                                                      </div>
                                                      <form method="POST"
                                                        action="/admin/capitulos/<%= c.id_capitulo %>/edit">
                                                        <div class="form-grid">
                                                          <div class="form-group span-full"><label>ID
                                                              Cuento</label><input type="number" name="cuento_id"
                                                              class="form-control" value="<%= c.cuento_id %>" required>
                                                          </div>
                                                          <div class="form-group span-full"><label>Título</label><input
                                                              type="text" name="titulo" class="form-control"
                                                              value="<%= c.titulo %>" required></div>
                                                        </div>
                                                        <div class="modal-footer">
                                                          <button type="button" class="btn btn-outline"
                                                            onclick="closeModal('modal-edit-cap-<%= c.id_capitulo %>')">Cancelar</button>
                                                          <button type="submit" class="btn btn-ok">Guardar</button>
                                                        </div>
                                                      </form>
                                                    </div>
                                                  </div>
                                                </td>
                                                <td>
                                                  <form method="POST"
                                                    action="/admin/capitulos/<%= c.id_capitulo %>/delete"
                                                    onsubmit="return confirm('¿Eliminar capítulo?')">
                                                    <button type="submit" class="btn btn-del btn-sm">Eliminar</button>
                                                  </form>
                                                </td>
                                              </tr>
                                              <% }) %>
                                          </tbody>
                                        </table>
                                      </div>
                                      <% } %>

                                        <!-- ====================================================
         ETIQUETAS
    ==================================================== -->
                                        <% } else if (seccion==='etiquetas' ) { %>
                                          <div class="page-header">
                                            <div>
                                              <h1 class="page-title">Gestión de Etiquetas</h1>
                                              <p class="page-subtitle">Etiquetas para clasificar el contenido</p>
                                            </div>
                                          </div>

                                          <div class="form-card">
                                            <h2>Nueva etiqueta</h2>
                                            <form method="POST" action="/admin/etiquetas/new" class="row-form">
                                              <input type="text" name="nombre" placeholder="Nombre de la etiqueta"
                                                required class="inp">
                                              <button type="submit" class="btn btn-ok">+ Crear</button>
                                            </form>
                                          </div>

                                          <% if (etiquetas.length===0) { %>
                                            <p>No hay etiquetas registradas.</p>
                                            <% } else { %>
                                              <div class="table-wrap">
                                                <table class="admin-table">
                                                  <thead>
                                                    <tr>
                                                      <th>#</th>
                                                      <th>Nombre</th>
                                                      <th>Editar</th>
                                                      <th>Eliminar</th>
                                                    </tr>
                                                  </thead>
                                                  <tbody>
                                                    <% etiquetas.forEach(e=> { %>
                                                      <tr>
                                                        <td>
                                                          <%= e.id_etiqueta %>
                                                        </td>
                                                        <td>
                                                          <form method="POST"
                                                            action="/admin/etiquetas/<%= e.id_etiqueta %>/edit"
                                                            class="row-form">
                                                            <input type="text" name="nombre" value="<%= e.nombre %>"
                                                              required class="inp inp-sm">
                                                            <button type="submit"
                                                              class="btn btn-edit btn-sm">Guardar</button>
                                                          </form>
                                                        </td>
                                                        <td>—</td>
                                                        <td>
                                                          <form method="POST"
                                                            action="/admin/etiquetas/<%= e.id_etiqueta %>/delete"
                                                            onsubmit="return confirm('¿Eliminar etiqueta?')">
                                                            <button type="submit"
                                                              class="btn btn-del btn-sm">Eliminar</button>
                                                          </form>
                                                        </td>
                                                      </tr>
                                                      <% }) %>
                                                  </tbody>
                                                </table>
                                              </div>
                                              <% } %>

                                                <!-- ====================================================
         NOTIFICACIONES
    ==================================================== -->
                                                <% } else if (seccion==='notificaciones' ) { %>
                                                  <div class="page-header">
                                                    <div>
                                                      <h1 class="page-title">Gestión de Notificaciones</h1>
                                                      <p class="page-subtitle">Envía y revisa notificaciones del sistema
                                                      </p>
                                                    </div>
                                                    <button type="button" class="btn btn-primary"
                                                      onclick="openModal('modal-new-notif')">+ Nueva
                                                      Notificación</button>
                                                  </div>

                                                  <!-- Modal: Nueva Notificación -->
                                                  <div id="modal-new-notif" class="modal-overlay">
                                                    <div class="modal-content">
                                                      <div class="modal-header">
                                                        <h2>Nueva Notificación</h2>
                                                        <button type="button" class="close-modal"
                                                          onclick="closeModal('modal-new-notif')">&times;</button>
                                                      </div>
                                                      <form method="POST" action="/admin/notificaciones/new">
                                                        <div class="form-grid">
                                                          <div class="form-group span-full">
                                                            <label>ID de Usuario Destinatario *</label>
                                                            <input type="number" name="cuenta_usuario_id"
                                                              class="form-control" placeholder="ID del usuario"
                                                              required>
                                                          </div>
                                                          <div class="form-group">
                                                            <label>Tipo *</label>
                                                            <input type="text" name="tipo" class="form-control"
                                                              placeholder="ej. bienvenida, alerta" required>
                                                          </div>
                                                          <div class="form-group span-full">
                                                            <label>Mensaje *</label>
                                                            <textarea name="mensaje" class="form-control"
                                                              placeholder="Texto de la notificación..."
                                                              required></textarea>
                                                          </div>
                                                        </div>
                                                        <div class="modal-footer">
                                                          <button type="button" class="btn btn-outline"
                                                            onclick="closeModal('modal-new-notif')">Cancelar</button>
                                                          <button type="submit" class="btn btn-ok">✓ Enviar
                                                            Notificación</button>
                                                        </div>
                                                      </form>
                                                    </div>
                                                  </div>

                                                  <% if (notificaciones.length===0) { %>
                                                    <p>No hay notificaciones registradas.</p>
                                                    <% } else { %>
                                                      <div class="table-wrap">
                                                        <table class="admin-table">
                                                          <thead>
                                                            <tr>
                                                              <th>#</th>
                                                              <th>Usuario</th>
                                                              <th>Tipo</th>
                                                              <th>Mensaje</th>
                                                              <th>Leída</th>
                                                              <th>Eliminar</th>
                                                            </tr>
                                                          </thead>
                                                          <tbody>
                                                            <% notificaciones.forEach(n=> { %>
                                                              <tr>
                                                                <td>
                                                                  <%= n.id_notificacion %>
                                                                </td>
                                                                <td>
                                                                  <%= n.cuenta_usuario_id %>
                                                                </td>
                                                                <td><span class="badge badge-blue">
                                                                    <%= n.tipo %>
                                                                  </span></td>
                                                                <td>
                                                                  <%= n.mensaje %>
                                                                </td>
                                                                <td><span
                                                                    class="badge <%= n.leida ? 'badge-green' : 'badge-gray' %>">
                                                                    <%= n.leida ? 'Sí' : 'No' %>
                                                                  </span></td>
                                                                <td>
                                                                  <form method="POST"
                                                                    action="/admin/notificaciones/<%= n.id_notificacion %>/delete"
                                                                    onsubmit="return confirm('¿Eliminar notificación?')">
                                                                    <button type="submit"
                                                                      class="btn btn-del btn-sm">Eliminar</button>
                                                                  </form>
                                                                </td>
                                                              </tr>
                                                              <% }) %>
                                                          </tbody>
                                                        </table>
                                                      </div>
                                                      <% } %>

                                                        <% } %>

    </main>
  </div>

  <script>
    // ── Modal ────────────────────────────────────────────────────
    function openModal(id) {
      const el = document.getElementById(id);
      if (el) { el.classList.add('active'); document.body.style.overflow = 'hidden'; }
    }
    function closeModal(id) {
      const el = document.getElementById(id);
      if (el) { el.classList.remove('active'); document.body.style.overflow = ''; }
    }
    // Cerrar modal al hacer clic fuera
    document.querySelectorAll('.modal-overlay').forEach(overlay => {
      overlay.addEventListener('click', function (e) {
        if (e.target === this) { this.classList.remove('active'); document.body.style.overflow = ''; }
      });
    });

    // ── Sidebar Mobile ───────────────────────────────────────────
    const sidebarToggle = document.getElementById('sidebarToggle');
    const adminSidebar = document.getElementById('adminSidebar');
    const backdrop = document.getElementById('sidebarBackdrop');

    sidebarToggle?.addEventListener('click', () => {
      adminSidebar.classList.toggle('open');
      backdrop.classList.toggle('active');
    });
    backdrop?.addEventListener('click', () => {
      adminSidebar.classList.remove('open');
      backdrop.classList.remove('active');
    });

    // ── Dashboard date ───────────────────────────────────────────
    const dashDateEl = document.getElementById('dashDate');
    if (dashDateEl) {
      const now = new Date();
      dashDateEl.textContent = now.toLocaleDateString('es', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
    }

    // ── Vista previa portada ─────────────────────────────────────
    function previewPortada(inputId, imgId) {
      const url = document.getElementById(inputId)?.value;
      const img = document.getElementById(imgId);
      if (!img) return;
      if (url) { img.src = url; img.style.display = 'block'; }
      else { img.style.display = 'none'; }
    }

    // ── Toast sistema ────────────────────────────────────────────
    function showToast(msg, type = 'success') {
      const container = document.getElementById('toastContainer');
      if (!container) return;
      const icons = { success: '✅', error: '❌', warning: '⚠️' };
      const toast = document.createElement('div');
      toast.className = `toast${type === 'error' ? ' toast-error' : type === 'warning' ? ' toast-warning' : ''}`;
      toast.innerHTML = `
      <span class="toast-icon">${icons[type] || '✅'}</span>
      <span class="toast-msg">${msg}</span>
      <button class="toast-close" onclick="dismissToast(this.parentElement)">×</button>
    `;
      container.appendChild(toast);
      setTimeout(() => dismissToast(toast), 5000);
    }

    function dismissToast(toast) {
      if (!toast || toast.classList.contains('removing')) return;
      toast.classList.add('removing');
      setTimeout(() => toast?.remove(), 300);
    }

    // Mostrar toast si hay mensaje en la URL
    (function () {
      const params = new URLSearchParams(window.location.search);
      const msg = params.get('msg');
      const error = params.get('error');
      if (msg) showToast(decodeURIComponent(msg.replace(/\+/g, ' ')), 'success');
      if (error) showToast(decodeURIComponent(error.replace(/\+/g, ' ')), 'error');
      // Limpiar la URL sin recargar
      if (msg || error) {
        const clean = window.location.pathname;
        window.history.replaceState({}, '', clean);
      }
    })();
  </script>

</body>

</html>