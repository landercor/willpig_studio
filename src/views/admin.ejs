<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Willpig Studio | Panel de Administrador</title>
  <link rel="stylesheet" href="/css/modules/views/admin.css" />
  <link rel="icon" href="/img/img.ico/GABALI baloo.ico">
</head>

<body>

  <!-- Sidebar backdrop (mobile) -->
  <div class="sidebar-backdrop" id="sidebarBackdrop"></div>

  <!-- Hamburger toggle -->
  <button class="sidebar-toggle" id="sidebarToggle" aria-label="Abrir menú">☰</button>

  <!-- Toast container -->
  <div class="toast-container" id="toastContainer"></div>

  <div class="admin-layout">

    <!-- ── SIDEBAR ── -->
    <aside class="admin-sidebar" id="adminSidebar">
      <div class="sidebar-header">
        <div class="sidebar-logo">
          <span class="logo-icon"><img src="/img/img.ico/svg/nut-fill.svg" alt=""></span>Willpig Admin
        </div>
        <div class="sidebar-user"><img src="/img/img.ico/svg/file-person.svg" alt="file-person">
          <%= loggerUser ? loggerUser.username : 'Admin' %>
        </div>
      </div>

      <nav class="sidebar-nav">
        <div class="nav-section-label">General</div>
        <a href="/admin" class="nav-link <%= seccion === 'dashboard'      ? 'active' : '' %>"><span class="icon"><img
              src="/img/img.ico/svg/file-person-fill.svg" alt="fill-person"></span> Dashboard</a>

        <div class="nav-section-label">Contenido</div>
        <a href="/admin/usuarios" class="nav-link <%= seccion === 'usuarios'       ? 'active' : '' %>"><span
            class="icon"><img src="/img/img.ico/svg/file-person.svg" alt="file-person"></span> Usuarios</a>
        <a href="/admin/historias" class="nav-link <%= seccion === 'historias'      ? 'active' : '' %>"><span
            class="icon"><img src="/img/img.ico/svg/book-half.svg" alt=""></span> Historias</a>
        <a href="/admin/capitulos" class="nav-link <%= seccion === 'capitulos'      ? 'active' : '' %>"><span
            class="icon"><img src="/img/img.ico/svg/journal-bookmark-fill.svg" alt=""></span> Capítulos</a>

        <div class="nav-section-label">Taxonomía</div>
        <a href="/admin/categorias" class="nav-link <%= seccion === 'categorias'     ? 'active' : '' %>"><span
            class="icon"><img src="/img/img.ico/svg/usb-c.svg" alt=""></span> Categorías</a>
        <a href="/admin/etiquetas" class="nav-link <%= seccion === 'etiquetas'      ? 'active' : '' %>"><span
            class="icon"><img src="/img/img.ico/svg/tag-fill.svg" alt=""></span> Etiquetas</a>

        <div class="nav-section-label">Sistema</div>
        <a href="/admin/notificaciones" class="nav-link <%= seccion === 'notificaciones' ? 'active' : '' %>"><span
            class="icon"><img src="/img/img.ico/svg/send-check-fill.svg" alt=""></span> Notificaciones</a>
      </nav>

      <div class="sidebar-footer">
        <a href="/" class="nav-link"><span class="icon"><img src="/img/img.ico/svg/arrow-bar-left.svg" alt=""></span>
          Volver al sitio</a>
      </div>
    </aside>

    <!-- ── CONTENIDO PRINCIPAL ── -->
    <main class="admin-main">

      <!-- ====================================================
         DASHBOARD
    ==================================================== -->
      <% if (seccion==='dashboard' ) { %>
        <div class="welcome-banner">
          <div>
            <h1>Bienvenido, <%= loggerUser ? loggerUser.username : 'Admin' %>
            </h1>
            <p>Panel de control de Willpig Studio — gestiona todo el contenido desde aquí.</p>
          </div>
          <div class="welcome-date" id="dashDate"></div>
        </div>

        <!-- Stats -->
        <div class="stats-grid">
          <a href="/admin/usuarios" class="stat-card">
            <div class="stat-icon blue"><img src="/img/img.ico/svg/file-person.svg" alt="">
            </div>
            <div class="stat-body">
              <span class="stat-num">
                <%= stats.totalUsuarios || 0 %>
              </span>
              <span class="stat-label">Usuarios</span>
            </div>
          </a>
          <a href="/admin/historias" class="stat-card">
            <div class="stat-icon green"><img src="/img/img.ico/svg/book-half.svg" alt="">
            </div>
            <div class="stat-body">
              <span class="stat-num">
                <%= stats.totalHistorias || 0 %>
              </span>
              <span class="stat-label">Historias</span>
            </div>
          </a>
          <a href="/admin/capitulos" class="stat-card">
            <div class="stat-icon purple"><img src="/img/img.ico/svg/journal-bookmark-fill.svg" alt="">
            </div>
            <div class="stat-body">
              <span class="stat-num">
                <%= stats.totalCapitulos || 0 %>
              </span>
              <span class="stat-label">Capítulos</span>
            </div>
          </a>
          <a href="/admin/categorias" class="stat-card">
            <div class="stat-icon orange"><img src="/img/img.ico/svg/usb-c.svg" alt=""></div>
            <div class="stat-body">
              <span class="stat-num">
                <%= stats.totalCategorias || 0 %>
              </span>
              <span class="stat-label">Categorías</span>
            </div>
          </a>
          <a href="/admin/etiquetas" class="stat-card">
            <div class="stat-icon teal"><img src="/img/img.ico/svg/tag-fill.svg" alt=""></div>
            <div class="stat-body">
              <span class="stat-num">
                <%= stats.totalEtiquetas || 0 %>
              </span>
              <span class="stat-label">Etiquetas</span>
            </div>
          </a>
          <a href="/admin/notificaciones" class="stat-card">
            <div class="stat-icon red"><img src="/img/img.ico/svg/send-check-fill.svg" alt="">
            </div>
            <div class="stat-body">
              <span class="stat-num">
                <%= stats.totalNotificaciones || 0 %>
              </span>
              <span class="stat-label">Notificaciones</span>
            </div>
          </a>
        </div>

        <!-- Accesos rápidos -->
        <p class="section-title"><img src="/img/img.ico/svg/ligthning-fill.svg" alt=""> Acciones rápidas</p>
        <div class="quick-grid">
          <a href="/admin/usuarios" class="quick-card">
            <span class="q-icon"><img src="/img/img.ico/svg/person-fill-add.svg" alt=""></span>
            <span class="q-label">Gestionar Usuarios</span>
            <span class="q-desc">Crear, editar, suspender</span>
          </a>
          <a href="/admin/historias" class="quick-card">
            <span class="q-icon"><img src="/img/img.ico/svg/book-half.svg" alt=""></span>
            <span class="q-label">Gestionar Historias</span>
            <span class="q-desc">Nueva historia, editar</span>
          </a>
          <a href="/admin/capitulos" class="quick-card">
            <span class="q-icon"><img src="/img/img.ico/svg/journal-bookmark-fill.svg" alt=""></span>
            <span class="q-label">Capítulos</span>
            <span class="q-desc">Añadir y organizar capítulos</span>
          </a>
          <a href="/admin/categorias" class="quick-card">
            <span class="q-icon"><img src="/img/img.ico/svg/usb-c.svg" alt=""></span>
            <span class="q-label">Categorías</span>
            <span class="q-desc">Crear y organizar categorías</span>
          </a>
          <a href="/admin/etiquetas" class="quick-card">
            <span class="q-icon"><img src="/img/img.ico/svg/tag-fill.svg" alt=""></span>
            <span class="q-label">Etiquetas</span>
            <span class="q-desc">Gestionar etiquetas</span>
          </a>
          <a href="/admin/notificaciones" class="quick-card">
            <span class="q-icon"><img src="/img/img.ico/svg/send-check-fill.svg" alt=""></span>
            <span class="q-label">Notificaciones</span>
            <span class="q-desc">Enviar y revisar notifs</span>
          </a>
        </div>

        <!-- ====================================================
         USUARIOS
    ==================================================== -->
        <% } else if (seccion==='usuarios' ) { %>
          <div class="page-header">
            <div>
              <h1 class="page-title">Gestión de Usuarios</h1>
              <p class="page-subtitle">Crea, edita o elimina cuentas de usuario</p>
            </div>
            <button type="button" class="btn btn-primary" onclick="openModal('modal-new-usuario')">
              + Nuevo Usuario
            </button>
          </div>

          <!-- Modal: Crear Usuario -->
          <div id="modal-new-usuario" class="modal-overlay">
            <div class="modal-content">
              <div class="modal-header">
                <h2>Crear Nuevo Usuario</h2>
                <button type="button" class="close-modal" onclick="closeModal('modal-new-usuario')">&times;</button>
              </div>
              <form method="POST" action="/admin/usuarios/new">
                <div class="form-grid">
                  <div class="form-group">
                    <label>Username *</label>
                    <input type="text" name="username" class="form-control" placeholder="nombre_usuario" required>
                  </div>
                  <div class="form-group">
                    <label>Email *</label>
                    <input type="email" name="email" class="form-control" placeholder="correo@ejemplo.com" required>
                  </div>
                  <div class="form-group">
                    <label>Contraseña temporal *</label>
                    <input type="password" name="password" class="form-control" placeholder="Mínimo 6 caracteres"
                      required minlength="6">
                  </div>
                  <div class="form-group">
                    <label>Rol</label>
                    <select name="rol" class="form-control">
                      <option value="lector">lector</option>
                      <option value="escritor">escritor</option>
                      <option value="moderador">moderador</option>
                      <option value="admin">admin</option>
                    </select>
                  </div>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-outline"
                    onclick="closeModal('modal-new-usuario')">Cancelar</button>
                  <button type="submit" class="btn btn-ok">✓ Crear Usuario</button>
                </div>
              </form>
            </div>
          </div>

          <% if (usuarios.length===0) { %>
            <p>No hay usuarios registrados.</p>
            <% } else { %>
              <div class="table-wrap">
                <table class="admin-table">
                  <thead>
                    <tr>
                      <th>#</th>
                      <th>Username</th>
                      <th>Email</th>
                      <th>Rol</th>
                      <th>Estado</th>
                      <th>Registrado</th>
                      <th>Acciones</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% usuarios.forEach(u=> { %>
                      <tr>
                        <td>
                          <%= u.id_cuenta_usuario %>
                        </td>
                        <td><strong>
                            <%= u.username %>
                          </strong></td>
                        <td>
                          <%= u.email %>
                        </td>
                        <td>
                          <span
                            class="badge <%= u.rol === 'admin' ? 'badge-red' : u.rol === 'moderador' ? 'badge-yellow' : u.rol === 'escritor' ? 'badge-blue' : 'badge-gray' %>">
                            <%= u.rol %>
                          </span>
                        </td>
                        <td>
                          <span
                            class="badge <%= u.estado === 'activa' ? 'badge-green' : u.estado === 'suspendida' ? 'badge-yellow' : 'badge-red' %>">
                            <%= u.estado %>
                          </span>
                        </td>
                        <td>
                          <%= u.fecha_registro ? new Date(u.fecha_registro).toLocaleDateString('es') : '—' %>
                        </td>
                        <td style="display:flex;gap:6px;flex-wrap:wrap">
                          <button type="button" class="btn btn-edit btn-sm"
                            onclick="openModal('modal-edit-usuario-<%= u.id_cuenta_usuario %>')">Editar</button>
                          <form method="POST" action="/admin/usuarios/<%= u.id_cuenta_usuario %>/delete"
                            onsubmit="return confirm('¿Eliminar usuario <%= u.username %>?')">
                            <button type="submit" class="btn btn-del btn-sm">Eliminar</button>
                          </form>
                        </td>
                      </tr>

                      <!-- Modal Edición Usuario -->
                      <div id="modal-edit-usuario-<%= u.id_cuenta_usuario %>" class="modal-overlay">
                        <div class="modal-content">
                          <div class="modal-header">
                            <h2>Editar: <%= u.username %>
                            </h2>
                            <button type="button" class="close-modal"
                              onclick="closeModal('modal-edit-usuario-<%= u.id_cuenta_usuario %>')">&times;</button>
                          </div>
                          <form method="POST" action="/admin/usuarios/<%= u.id_cuenta_usuario %>/edit">
                            <div class="form-grid">
                              <div class="form-group">
                                <label>Username</label>
                                <input type="text" name="username" class="form-control" value="<%= u.username %>"
                                  required>
                              </div>
                              <div class="form-group">
                                <label>Email</label>
                                <input type="email" name="email" class="form-control" value="<%= u.email %>" required>
                              </div>
                              <div class="form-group">
                                <label>Rol</label>
                                <select name="rol" class="form-control">
                                  <option value="lector" <%=u.rol==='lector' ? 'selected' : '' %>>lector</option>
                                  <option value="escritor" <%=u.rol==='escritor' ? 'selected' : '' %>>escritor</option>
                                  <option value="moderador" <%=u.rol==='moderador' ? 'selected' : '' %>>moderador
                                  </option>
                                  <option value="admin" <%=u.rol==='admin' ? 'selected' : '' %>>admin</option>
                                </select>
                              </div>
                              <div class="form-group">
                                <label>Estado</label>
                                <select name="estado" class="form-control">
                                  <option value="activa" <%=u.estado==='activa' ? 'selected' : '' %>>activa</option>
                                  <option value="suspendida" <%=u.estado==='suspendida' ? 'selected' : '' %>>suspendida
                                  </option>
                                  <option value="deshabilitada" <%=u.estado==='deshabilitada' ? 'selected' : '' %>
                                    >deshabilitada</option>
                                </select>
                              </div>
                            </div>
                            <div class="modal-footer">
                              <button type="button" class="btn btn-outline"
                                onclick="closeModal('modal-edit-usuario-<%= u.id_cuenta_usuario %>')">Cancelar</button>
                              <button type="submit" class="btn btn-ok">Guardar</button>
                            </div>
                          </form>
                        </div>
                      </div>
                      <% }) %>
                  </tbody>
                </table>
              </div>
              <% } %>

                <!-- ====================================================
         HISTORIAS
    ==================================================== -->
                <% } else if (seccion==='historias' ) { %>
                  <div class="page-header">
                    <div>
                      <h1 class="page-title">Gestión de Historias</h1>
                      <p class="page-subtitle">Crea y administra todas las historias de la plataforma</p>
                    </div>
                    <button type="button" class="btn btn-primary" onclick="openModal('modal-new-historia')">
                      + Nueva Historia
                    </button>
                  </div>

                  <!-- Modal: Crear Historia -->
                  <div id="modal-new-historia" class="modal-overlay">
                    <div class="modal-content" style="max-width:640px">
                      <div class="modal-header">
                        <h2>Nueva Historia</h2>
                        <button type="button" class="close-modal"
                          onclick="closeModal('modal-new-historia')">&times;</button>
                      </div>
                      <form method="POST" action="/admin/historias/new">
                        <div class="form-grid">
                          <div class="form-group span-full">
                            <label>Título *</label>
                            <input type="text" name="titulo" class="form-control" placeholder="Título de la historia"
                              required>
                          </div>
                          <div class="form-group span-full">
                            <label>Descripción / Sinopsis</label>
                            <textarea name="descripcion" class="form-control"
                              placeholder="Escribe una breve descripción..."></textarea>
                          </div>
                          <div class="form-group span-full">
                            <label>URL de Portada</label>
                            <input type="url" name="portada_url" id="newPortadaUrl" class="form-control"
                              placeholder="https://..." oninput="previewPortada('newPortadaUrl','newPortadaPreview')">
                            <img id="newPortadaPreview" class="portada-preview" alt="Vista previa portada">
                          </div>
                          <div class="form-group">
                            <label>Categoría</label>
                            <select name="categoria_id" class="form-control">
                              <option value="">Sin categoría</option>
                              <% (categorias || []).forEach(cat=> { %>
                                <option value="<%= cat.id_categoria %>">
                                  <%= cat.nombre %>
                                </option>
                                <% }) %>
                            </select>
                          </div>
                          <div class="form-group">
                            <label>Estado</label>
                            <select name="estado" class="form-control">
                              <option value="borrador">Borrador</option>
                              <option value="progreso">En progreso</option>
                              <option value="publicado">Publicado</option>
                            </select>
                          </div>
                          <div class="form-group">
                            <label>Visibilidad</label>
                            <select name="visibilidad" class="form-control">
                              <option value="publica">Pública</option>
                              <option value="privada">Privada</option>
                            </select>
                          </div>
                          <div class="form-group">
                            <label>Audiencia</label>
                            <select name="audiencia" class="form-control">
                              <option value="general">General</option>
                              <option value="adolescentes">Adolescentes</option>
                              <option value="adultos">Adultos</option>
                            </select>
                          </div>
                          <div class="form-group">
                            <label>Idioma</label>
                            <select name="idioma" class="form-control">
                              <option value="es">Español</option>
                              <option value="en">Inglés</option>
                            </select>
                          </div>
                          <div class="form-group">
                            <label>Derechos</label>
                            <select name="derechos" class="form-control">
                              <option value="todos">Todos los derechos</option>
                              <option value="compartido">Compartido</option>
                              <option value="libre">Libre</option>
                            </select>
                          </div>
                          <div class="form-group">
                            <label>Clasificación</label>
                            <select name="clasificacion" class="form-control">
                              <option value="todo">Todo público</option>
                              <option value="maduro">Contenido maduro</option>
                            </select>
                          </div>
                        </div>
                        <div class="modal-footer">
                          <button type="button" class="btn btn-outline"
                            onclick="closeModal('modal-new-historia')">Cancelar</button>
                          <button type="submit" class="btn btn-ok">✓ Crear Historia</button>
                        </div>
                      </form>
                    </div>
                  </div>

                  <% if (historias.length===0) { %>
                    <p>No hay historias registradas. ¡Crea la primera!</p>
                    <% } else { %>
                      <div class="table-wrap">
                        <table class="admin-table">
                          <thead>
                            <tr>
                              <th>#</th>
                              <th>Título</th>
                              <th>Autor</th>
                              <th>Estado</th>
                              <th>Visibilidad</th>
                              <th>Vistas</th>
                              <th>Fecha</th>
                              <th>Acciones</th>
                            </tr>
                          </thead>
                          <tbody>
                            <% historias.forEach(h=> { %>
                              <tr>
                                <td>
                                  <%= h.id_cuento %>
                                </td>
                                <td>
                                  <a href="/historias/<%= h.id_cuento %>" target="_blank" class="link-title">
                                    <%= h.titulo %>
                                  </a>
                                </td>
                                <td>
                                  <%= h.cuenta_usuario ? h.cuenta_usuario.username : '—' %>
                                </td>
                                <td>
                                  <span
                                    class="badge <%= h.estado === 'publicado' ? 'badge-green' : h.estado === 'progreso' ? 'badge-yellow' : 'badge-gray' %>">
                                    <%= h.estado %>
                                  </span>
                                </td>
                                <td>
                                  <span class="badge <%= h.visibilidad === 'publica' ? 'badge-blue' : 'badge-gray' %>">
                                    <%= h.visibilidad %>
                                  </span>
                                </td>
                                <td>
                                  <%= (h.vistas || 0).toLocaleString() %>
                                </td>
                                <td>
                                  <%= h.created_at ? new Date(h.created_at).toLocaleDateString('es') : '—' %>
                                </td>
                                <td style="display:flex;gap:6px;flex-wrap:wrap">
                                  <button type="button" class="btn btn-edit btn-sm"
                                    onclick="openModal('modal-edit-historia-<%= h.id_cuento %>')">Editar</button>
                                  <form method="POST" action="/admin/historias/<%= h.id_cuento %>/delete"
                                    onsubmit="return confirm('¿Eliminar historia: <%= h.titulo %>?')">
                                    <button type="submit" class="btn btn-del btn-sm">Eliminar</button>
                                  </form>
                                </td>
                              </tr>

                              <!-- Modal Editar Historia -->
                              <div id="modal-edit-historia-<%= h.id_cuento %>" class="modal-overlay">
                                <div class="modal-content" style="max-width:640px">
                                  <div class="modal-header">
                                    <h2>Editar: <%= h.titulo %>
                                    </h2>
                                    <button type="button" class="close-modal"
                                      onclick="closeModal('modal-edit-historia-<%= h.id_cuento %>')">&times;</button>
                                  </div>
                                  <form method="POST" action="/admin/historias/<%= h.id_cuento %>/edit">
                                    <div class="form-grid">
                                      <div class="form-group span-full">
                                        <label>Título</label>
                                        <input type="text" name="titulo" class="form-control" value="<%= h.titulo %>"
                                          required>
                                      </div>
                                      <div class="form-group span-full">
                                        <label>Descripción</label>
                                        <textarea name="descripcion"
                                          class="form-control"><%= h.descripcion || '' %></textarea>
                                      </div>
                                      <div class="form-group span-full">
                                        <label>URL Portada</label>
                                        <input type="url" name="portada_url" id="portada_<%= h.id_cuento %>"
                                          class="form-control" value="<%= h.portada_url || '' %>"
                                          oninput="previewPortada('portada_<%= h.id_cuento %>','prev_<%= h.id_cuento %>')">
                                        <% if (h.portada_url) { %>
                                          <img id="prev_<%= h.id_cuento %>" class="portada-preview"
                                            src="<%= h.portada_url %>" alt="portada" style="display:block">
                                          <% } else { %>
                                            <img id="prev_<%= h.id_cuento %>" class="portada-preview" alt="portada">
                                            <% } %>
                                      </div>
                                      <div class="form-group">
                                        <label>Categoría</label>
                                        <select name="categoria_id" class="form-control">
                                          <option value="">Sin categoría</option>
                                          <% (categorias || []).forEach(cat=> { %>
                                            <option value="<%= cat.id_categoria %>" <%=h.categoria_id==cat.id_categoria
                                              ? 'selected' : '' %>><%= cat.nombre %>
                                            </option>
                                            <% }) %>
                                        </select>
                                      </div>
                                      <div class="form-group">
                                        <label>Estado</label>
                                        <select name="estado" class="form-control">
                                          <option value="borrador" <%=h.estado==='borrador' ? 'selected' : '' %>
                                            >Borrador</option>
                                          <option value="progreso" <%=h.estado==='progreso' ? 'selected' : '' %>>En
                                            progreso</option>
                                          <option value="publicado" <%=h.estado==='publicado' ? 'selected' : '' %>
                                            >Publicado</option>
                                        </select>
                                      </div>
                                      <div class="form-group">
                                        <label>Visibilidad</label>
                                        <select name="visibilidad" class="form-control">
                                          <option value="publica" <%=h.visibilidad==='publica' ? 'selected' : '' %>
                                            >Pública</option>
                                          <option value="privada" <%=h.visibilidad==='privada' ? 'selected' : '' %>
                                            >Privada</option>
                                        </select>
                                      </div>
                                      <div class="form-group">
                                        <label>Audiencia</label>
                                        <select name="audiencia" class="form-control">
                                          <option value="general" <%=h.audiencia==='general' ? 'selected' : '' %>
                                            >General</option>
                                          <option value="adolescentes" <%=h.audiencia==='adolescentes' ? 'selected' : ''
                                            %>>Adolescentes</option>
                                          <option value="adultos" <%=h.audiencia==='adultos' ? 'selected' : '' %>
                                            >Adultos</option>
                                        </select>
                                      </div>
                                      <div class="form-group">
                                        <label>Idioma</label>
                                        <select name="idioma" class="form-control">
