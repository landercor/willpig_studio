                                        <td>—</td>
                                        <td>
                                          <form method="POST" action="/admin/categorias/<%= c.id_categoria %>/delete"
                                            onsubmit="return confirm('¿Eliminar categoría <%= c.nombre %>?')">
                                            <button type="submit" class="btn btn-del btn-sm">Eliminar</button>
                                          </form>
                                        </td>
                                      </tr>
                                      <% }) %>
                                  </tbody>
                                </table>
                              </div>
                              <% } %>

                                <!-- ====================================================
         CAPÍTULOS
    ==================================================== -->
                                <% } else if (seccion==='capitulos' ) { %>
                                  <div class="page-header">
                                    <div>
                                      <h1 class="page-title">Gestión de Capítulos</h1>
                                      <p class="page-subtitle">Administra los capítulos de todas las historias</p>
                                    </div>
