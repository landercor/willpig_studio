                                      <button type="submit" class="btn btn-ok">Guardar</button>
                                    </div>
                                  </form>
                                </div>
                              </div>
                              <% }) %>
                          </tbody>
                        </table>
                      </div>
                      <% } %>

                        <!-- ====================================================
         CATEGORÍAS
    ==================================================== -->
                        <% } else if (seccion==='categorias' ) { %>
                          <div class="page-header">
                            <div>
                              <h1 class="page-title">Gestión de Categorías</h1>
                              <p class="page-subtitle">Organiza las historias por categoría</p>
                            </div>
                          </div>

                          <div class="form-card">
                            <h2>Nueva categoría</h2>
                            <form method="POST" action="/admin/categorias/new" class="row-form">
                              <input type="text" name="nombre" placeholder="Nombre de la categoría" required
