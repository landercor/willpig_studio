<header class="navbar glass-effect">

  <div class="logo" onclick="window.location.href='/'">
    <figure class="logo-fig">
      <img src="/img/img.ico/logo.ico" alt="WillPig logo">
    </figure>
    <span class="logo-text">WillPig</span>
  </div>

  <form action="/buscar" method="GET" class="search-form">
    <div class="search-container">
      <input type="text" name="q" class="search-bar" placeholder="Buscar historias o autores..." required>
      <button type="submit" class="search-btn">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </button>
    </div>
  </form>

  <div class="nav-actions">

    <% if (loggerUser) { %>

      <!-- ESCRIBIR -->
      <div class="dropdown">
        <div class="dropdown-trigger">
          <button class="dropbtn">Escribir</button>
          <span class="dropdown-arrow">&#9662;</span>
        </div>
        <div class="dropdown-content glass-effect">
          <a href="/historias/crear">Crea tu historia</a>
          <a href="/historias/mis">Mis historias</a>
        </div>
      </div>

      <!-- EXPLORAR -->
      <div class="dropdown">
        <div class="dropdown-trigger">
          <button class="dropbtn">Explorar</button>
          <span class="dropdown-arrow">&#9662;</span>
        </div>
        <div class="dropdown-content glass-effect">
          <a href="/categoria/ficcion">Ficción</a>
          <a href="/categoria/fantasia">Fantasía</a>
          <a href="/categoria/aventura">Aventura</a>
        </div>
      </div>

      <!-- PERFIL -->
      <div class="dropdown profile">
        <img src="<%= loggerUser.avatar || '/img/default-avatar.png' %>" class="avatar avatar-sm">
        <span class="dropdown-arrow">&#9662;</span>
        <div class="dropdown-content glass-effect">
          <a href="/usuario/perfil">Mi perfil</a>
          <a href="/principal/biblioteca">Biblioteca</a>
          <a href="/auth/logout" class="logout-link">Cerrar sesión</a>
        </div>
      </div>

      <% } else { %>

        <a href="/auth/login" class="nav-link">Iniciar sesión</a>
        <a href="/auth/register" class="btn-primary-pastel">Registrarse</a>

        <% } %>

  </div>

  <button class="theme-toggle-btn" id="theme-toggle" aria-label="Cambiar tema">
    <div class="toggle-icon">
      <svg class="sun-icon" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor"
        stroke-width="2">
        <circle cx="12" cy="12" r="5"></circle>
        <line x1="12" y1="1" x2="12" y2="3"></line>
        <line x1="12" y1="21" x2="12" y2="23"></line>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
        <line x1="1" y1="12" x2="3" y2="12"></line>
        <line x1="21" y1="12" x2="23" y2="12"></line>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
      </svg>
      <svg class="moon-icon" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor"
        stroke-width="2">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
      </svg>
    </div>
  </button>
</header>