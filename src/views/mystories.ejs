<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    <%= tituloPagina %>
  </title>
  <link rel="stylesheet" href="/css/style1.2.css" />
  <link rel="stylesheet" href="/css/modules/views/mystories.css">
  <link rel="icon" href="/img/img.ico/GABALI baloo.ico">
</head>

<body>

  <%- include('partials/navbar', { loggerUser }) %>

    <main class="library-page">
      <header class="library-header">
        <h2>Mis Historias</h2>
        <a href="/historias/crear" class="btn-savever">+ Nueva Historia</a>
      </header>

      <div class="library-tabs">
        <button class="tab-btn active" data-target="published-tab">Publicadas (<%= stories.filter(s=> s.estado ===
            'publicado').length %>)</button>
        <button class="tab-btn" data-target="drafts-tab">Borradores (<%= stories.filter(s=> s.estado ===
            'borrador').length %>)</button>
      </div>

      <div class="library-content">

        <!-- === TAB: PUBLICADAS === -->
        <div id="published-tab" class="tab-content active">
          <div class="books-grid">
            <% const published=stories.filter(s=> s.estado === 'publicado'); %>
              <% if (published.length> 0) { %>
                <% published.forEach(historia=> { %>
                  <div class="book-card">
                    <a href="/historias/<%= historia.id_cuento %>">
                      <img src="<%= historia.portada_url || '/img/default-portada.jpg' %>" class="book-cover"
                        alt="<%= historia.titulo %>">
                    </a>
                    <p class="book-title">
                      <%= historia.titulo || 'Sin título' %>
                    </p>
                    <div class="book-meta">
                      <svg viewBox="0 0 16 16" width="12" height="12" fill="currentColor">
                        <path d="M10.5 8a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0z"/>
                        <path d="M0 8s3-5.5 8-5.5S16 8 16 8s-3 5.5-8 5.5S0 8 0 8zm8 3.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7z"/>
                      </svg>
                      <%= historia.vistas || 0 %> vistas
                    </div>
                    <div class="item-actions">
                      <a href="/historias/editar/<%= historia.id_cuento %>">Editar</a>
                    </div>
                  </div>
                  <% }) %>
                    <% } else { %>
                      <div class="empty-state empty-state-full">
                        <p>Aún no tienes historias publicadas.</p>
                      </div>
                      <% } %>
          </div>
        </div>

        <!-- === TAB: BORRADORES === -->
        <div id="drafts-tab" class="tab-content">
          <div class="books-grid">
            <% const drafts=stories.filter(s=> s.estado === 'borrador'); %>
              <% if (drafts.length> 0) { %>
                <% drafts.forEach(historia=> { %>
                  <div class="book-card">
                    <a href="/historias/<%= historia.id_cuento %>">
                      <span class="book-badge borrador">Borrador</span>
                      <img src="<%= historia.portada_url || '/img/default-portada.jpg' %>" class="book-cover"
                        alt="<%= historia.titulo %>" class="draft-cover">
                    </a>
                    <p class="book-title">
                      <%= historia.titulo || 'Sin título' %>
                    </p>
                    <div class="item-actions">
                      <a href="/historias/editar/<%= historia.id_cuento %>">Continuar</a>
                    </div>
                  </div>
                  <% }) %>
                    <% } else { %>
                      <div class="empty-state empty-state-full">
                        <p>No tienes borradores pendientes.</p>
                      </div>
                      <% } %>
          </div>
        </div>

      </div>
    </main>

    <%- include('partials/footer') %>

      <script>
        const tabs = document.querySelectorAll('.tab-btn');
        const contents = document.querySelectorAll('.tab-content');

        tabs.forEach(tab => {
          tab.addEventListener('click', () => {
            tabs.forEach(btn => btn.classList.remove('active'));
            contents.forEach(content => content.classList.remove('active'));

            tab.classList.add('active');
            document.getElementById(tab.dataset.target).classList.add('active');
          });
        });
      </script>
</body>

</html>
