<%- include('layouts/header', { title: 'Registrarse | Willpig Studio' , pageId: 'register' }) %>

    <main class="register-container-igm">
        <div class="register-card">
            <h1>Crear una cuenta</h1>
            <p>Únete a Willpig Studio y comparte tus historias ilustradas.</p>

            <!-- Mostrar error si existe -->
            <% if (typeof error !=="undefined" ) { %>
                <p style="color:red; text-align:center; margin-bottom:10px;">
                    <%= error %>
                </p>
                <% } %>

                    <% if (typeof success !=="undefined" ) { %>
                        <div class="success-message">
                            <%= success %>
                        </div>
                        <% } %>

                            <form action="/auth/register" method="POST" class="register-form">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <input type="hidden" name="next" value="<%= typeof next !== 'undefined' ? next : '' %>">
                                <div class="form-group">
                                    <label for="username">Nombre de usuario</label>
                                    <input type="text" id="username" name="username" placeholder="Tu nombre" required />
                                </div>

                                <div class="form-group">
                                    <label for="correo">Correo electrónico</label>
                                    <input type="email" id="correo" name="correo" placeholder="ejemplo@email.com"
                                        required />
                                </div>

                                <div class="form-group">
                                    <label for="contrasena">Contraseña</label>
                                    <input type="password" id="contrasena" name="contrasena"
                                        placeholder="Crea una contraseña segura" required />
                                </div>

                                <div class="form-group"
                                    style="display: flex; align-items: center; gap: 10px; margin-top: 15px; margin-bottom: 15px;">
                                    <input type="checkbox" id="terminos" name="terminos" required
                                        style="width: auto; margin: 0; cursor: pointer;">
                                    <label for="terminos"
                                        style="margin: 0; font-size: 0.9em; font-weight: normal; cursor: pointer;">
                                        He leído y acepto los <a href="/auth/register#terms-modal" id="open-terms-modal"
                                            style="color: #ff6b6b; text-decoration: underline;">Términos y
                                            Condiciones</a>
                                    </label>
                                </div>

                                <button type="submit" class="btn-register">Registrarse</button>
                            </form>

                            <div class="divider"> O continúa con </div>

                            <div class="social-login">
                                <a href="/auth/google" style="text-decoration: none; width: 100%;">
                                    <button type="button" class="social-btn google">
                                        <img src="/img/img.ico/google_login_color.png" width="20" alt="Google logo">
                                        Continuar con Google
                                    </button>
                                </a>
                            </div>
                            <p class="login-link">
                                ¿Ya tienes cuenta? <a href="/auth/login">Inicia sesión</a>
                            </p>
        </div>
    </main>

    <!-- Modal de Términos y Condiciones -->
    <dialog id="terms-modal" class="terms-modal"
        style="padding: 20px; border: none; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.3); max-width: 500px; width: 90%; color: #333;">
        <div
            style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #eee; padding-bottom: 10px; margin-bottom: 15px;">
            <h2 style="margin: 0; font-size: 1.2rem; color: #333;">Términos y Condiciones</h2>
            <button id="close-terms-modal"
                style="background: none; border: none; font-size: 1.5rem; cursor: pointer; color: #666;">&times;</button>
        </div>
        <div style="max-height: 60vh; overflow-y: auto; line-height: 1.6; font-size: 0.95rem; text-align: left;">
            <p style="margin-bottom: 10px;"><strong>1. Aceptación de los términos:</strong> Al registrarte en Willpig
                Studio, aceptas cumplir con nuestras políticas de uso y comportamiento en la plataforma.</p>
            <p style="margin-bottom: 10px;"><strong>2. Propiedad intelectual:</strong> Todas las historias y obras
                compartidas por ti siguen siendo de tu propiedad. Sin embargo, nos otorgas licencia para mostrarlas
                dentro de la plataforma de Willpig Studio.</p>
            <p style="margin-bottom: 10px;"><strong>3. Conducta del usuario:</strong> No está permitido subir contenido
                ofensivo, ilegal o que infrinja los derechos de autor de terceros.</p>
            <p style="margin-bottom: 10px;"><strong>4. Privacidad:</strong> Tu información personal será tratada
                conforme a nuestra Política de Privacidad. No compartiremos tus datos con terceros sin tu consentimiento
                explícito.</p>
            <p style="margin-bottom: 10px;"><strong>5. Modificaciones:</strong> Nos reservamos el derecho de modificar
                estos términos en cualquier momento, lo cual será notificado a través de la plataforma.</p>
        </div>
        <div style="text-align: right; margin-top: 20px; border-top: 1px solid #eee; padding-top: 15px;">
            <button id="accept-terms-btn"
                style="background-color: #ff6b6b; color: white; border: none; padding: 10px 20px; border-radius: 5px; cursor: pointer; font-weight: bold;">Aceptar
                y cerrar</button>
        </div>
    </dialog>

    <style>
        dialog::backdrop {
            background: rgba(0, 0, 0, 0.5);
        }
    </style>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const termsModal = document.getElementById('terms-modal');
            const openTermsModal = document.getElementById('open-terms-modal');
            const closeTermsModal = document.getElementById('close-terms-modal');
            const acceptTermsBtn = document.getElementById('accept-terms-btn');
            const terminosCheckbox = document.getElementById('terminos');

            if (openTermsModal && termsModal) {
                openTermsModal.addEventListener('click', (e) => {
                    e.preventDefault();
                    termsModal.showModal();
                });
            }

            if (closeTermsModal && termsModal) {
                closeTermsModal.addEventListener('click', () => {
                    termsModal.close();
                });
            }

            if (acceptTermsBtn && termsModal && terminosCheckbox) {
                acceptTermsBtn.addEventListener('click', () => {
                    terminosCheckbox.checked = true;
                    termsModal.close();
                });
            }

            // Cerrar al hacer clic fuera del modal
            if (termsModal) {
                termsModal.addEventListener('click', (e) => {
                    const dialogDimensions = termsModal.getBoundingClientRect();
                    if (
                        e.clientX < dialogDimensions.left ||
                        e.clientX > dialogDimensions.right ||
                        e.clientY < dialogDimensions.top ||
                        e.clientY > dialogDimensions.bottom
                    ) {
                        termsModal.close();
                    }
                });
            }
        });
    </script>

    <%- include('layouts/footer') %>